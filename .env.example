# Copy to .env and edit. Same file is used for dev and prod (different
# values per environment). See notes/deploy.md for production setup.

APP_ENV=development
APP_DEBUG=true

# PHP-side DB credentials (read by PdoFactory)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=the_saiged
DB_USER=the_saiged
DB_PASS=dev

# MySQL container credentials (read by docker-compose.prod.yml).
# DB_PASS above must match MYSQL_PASSWORD.
MYSQL_PASSWORD=dev
MYSQL_ROOT_PASSWORD=dev

# Absolute path to the htpasswd file for nginx basic auth (production only).
HTPASSWD_PATH=/home/admin/the-saiged/.htpasswd
