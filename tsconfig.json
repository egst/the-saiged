{
    "compilerOptions": {
        "target":           "es2022",
        "module":           "esnext",
        "moduleResolution": "bundler",
        "allowJs":          true,
        "checkJs":          true,
        "noEmit":           true,
        "strict":           true,
        "esModuleInterop":  true,
        "skipLibCheck":     true,
        "paths": {
            "/js/*":       ["./public/js/*"],
            "/sections/*": ["./src/Sections/*"]
        }
    },
    "include": [
        "public/js/**/*.js",
        "src/Sections/**/Admin/*.js",
        "tests/js/**/*.js"
    ]
}
