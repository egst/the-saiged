{
    "name": "egst/the-saiged",
    "description": "Web portfolio with a custom CMS",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "php-di/php-di": "^7.0"
    },
    "require-dev": {
        "dg/bypass-finals": "^1.10",
        "jetbrains/phpstorm-stubs": "^2026.1",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "TheSaiged\\":            "src/",
            "TheSaiged\\Migrations\\": "migrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TheSaiged\\Tests\\Unit\\":        "tests/unit/",
            "TheSaiged\\Tests\\Integration\\": "tests/integration/",
            "TheSaiged\\Tests\\":              "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "stan":      "phpstan analyze --memory-limit=256M",
        "test":      "phpunit --testdox",
        "test:unit": "phpunit --testdox --testsuite=Unit",
        "check":     ["@stan", "@test"],
        "migrate":   "php scripts/migrate.php"
    }
}
